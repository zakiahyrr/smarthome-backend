APP_ENV=production
SECRET_KEY=generate-a-long-random-secret
SESSION_COOKIE_SECURE=true
MAX_UPLOAD_BYTES=2097152
ALLOW_REGISTRATION=true
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=smarthome_app
MYSQL_PASS=replace-with-database-password
MYSQL_DB=smarthome_db
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TLS=false
MQTT_USER=smarthome_backend
MQTT_PASS=replace-with-backend-mqtt-password
CONTROLLER_API_TOKEN=replace-with-controller-token
CAMERA_API_TOKEN=replace-with-camera-token
